# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=<YOUR-TOKEN>           # https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_SP_FIELD=customfield_10016       # Custom field ID for Story Points (default works for most Jira clouds)
JIRA_PM_PROJECT_KEY=<PM-PROJECT-KEY>  # Project containing Value Milestones (used by Roadmap page)
# JIRA_PROJECT_KEY is stored per-team in data/teams/{id}/config.json (set via Setup or Settings)

# ── Rootly (On-Call) ──────────────────────────────────────────────────────────
ROOTLY_TOKEN=<YOUR-TOKEN>             # https://rootly.com/account/api-keys
# oncall_schedule_id is stored per-team in data/teams/{id}/config.json (set via Setup or Settings)

# ── EOM (OutSystems Engineering Org Management) ───────────────────────────────
EOM_TOKEN=<YOUR-TOKEN>                # https://apps.outsystems.app/EOM/TokenGeneration
# oncall_supervisor (manager name for filtering direct reports) is stored in config.json

# ── Slack (via Claude MCP) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-<YOUR-KEY>   # https://console.anthropic.com/settings/keys
MCP_SLACK_URL=<YOUR-MCP-URL>          # Remote MCP URL for your claude.ai Slack integration
MCP_SLACK_TOKEN=<YOUR-MCP-TOKEN>      # OAuth token for the MCP server (if required)
# slack_support_channel is stored per-team in data/teams/{id}/config.json (set via Support page)
